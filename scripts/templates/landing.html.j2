<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Blueprints</title>
  <style>
    :root {
      --bg: #f6f7f9;
      --card: #ffffff;
      --ink: #1b1f24;
      --muted: #5c6773;
      --accent: #2563eb;
      --border: #e3e7ec;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      color: var(--ink);
      background: var(--bg);
      line-height: 1.5;
    }
    .wrap { max-width: 60rem; margin: 0 auto; padding: 3rem 1.25rem 4rem; }
    header { margin-bottom: 2rem; }
    h1 { font-size: 2rem; margin: 0 0 .35rem; }
    .subtitle { color: var(--muted); margin: 0; }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
      gap: 1.1rem;
    }
    .card {
      display: flex;
      flex-direction: column;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: .7rem;
      padding: 1.15rem 1.2rem 1.1rem;
      transition: box-shadow .15s ease, transform .15s ease;
    }
    .card:hover { box-shadow: 0 6px 22px rgba(20, 30, 50, .09); transform: translateY(-2px); }
    .card h2 { font-size: 1.15rem; margin: 0 0 .4rem; }
    .card h2 a { color: var(--ink); text-decoration: none; }
    .card h2 a:hover { color: var(--accent); }
    .card p { color: var(--muted); margin: 0 0 1rem; flex: 1 1 auto; }
    .links { display: flex; flex-wrap: wrap; gap: .5rem; align-items: center; }
    .btn {
      display: inline-block;
      font-size: .85rem;
      text-decoration: none;
      padding: .35rem .7rem;
      border-radius: .45rem;
      border: 1px solid var(--border);
      color: var(--accent);
      background: #fff;
    }
    .btn.primary { background: var(--accent); color: #fff; border-color: var(--accent); }
    .btn:hover { filter: brightness(.97); }
    .empty { color: var(--muted); background: var(--card); border: 1px dashed var(--border);
             border-radius: .7rem; padding: 2rem; text-align: center; }
    footer { margin-top: 3rem; color: var(--muted); font-size: .85rem; }
    footer code { background: #eceff3; padding: .1rem .35rem; border-radius: .3rem; }
  </style>
</head>
<body>
  <div class="wrap">
    <header>
      <h1>Blueprints</h1>
      <p class="subtitle">Lean-style blueprints rendered with plasTeX &mdash; no Lean toolchain required.</p>
    </header>

    {% if blueprints %}
    <main class="grid">
      {% for bp in blueprints %}
      <article class="card">
        <h2><a href="{{ bp.url }}">{{ bp.title }}</a></h2>
        {% if bp.description %}
        <p>{{ bp.description }}</p>
        {% else %}
        <p></p>
        {% endif %}
        <div class="links">
          <a class="btn primary" href="{{ bp.url }}">Open blueprint</a>
          {% if bp.pdf_url %}
          <a class="btn" href="{{ bp.pdf_url }}">PDF</a>
          {% endif %}
          {% if bp.home %}
          <a class="btn" href="{{ bp.home }}">Home</a>
          {% endif %}
          {% if bp.github %}
          <a class="btn" href="{{ bp.github }}">GitHub</a>
          {% endif %}
        </div>
      </article>
      {% endfor %}
    </main>
    {% else %}
    <div class="empty">No blueprints yet. Add one under <code>blueprints/</code> and rebuild.</div>
    {% endif %}

    <footer>
      Built with <a href="https://github.com/PatrickMassot/leanblueprint">leanblueprint</a> + plasTeX.
    </footer>
  </div>
</body>
</html>
